homingPower: 0.1
homingDelay: 30

velocityScaleRandMin: 0.95
velocityScaleRandMax: 1.05

lifeScaleRandMin: 0.95
lifeScaleRandMax: 1.05  

width: 8.5
height: 15
layer: 77

despawnHit: true
